{
  "name": "sofret-mariane",
  "version": "1.0.0",
  "description": "Sofret Mariane — Egyptian catering site + PWA + Capacitor wrapper for iOS/Android.",
  "private": true,
  "scripts": {
    "start": "npx serve -l 5173 .",
    "serve": "python3 -m http.server 5173",
    "lh": "npx lighthouse http://localhost:5173 --view",
    "cap:init": "npx cap init 'Sofret Mariane' com.sofretmariane.app --web-dir=.",
    "cap:add:ios": "npx cap add ios && npx cap sync ios",
    "cap:add:android": "npx cap add android && npx cap sync android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  }
}

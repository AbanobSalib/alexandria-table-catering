{
  "appId": "com.sofretmariane.app",
  "appName": "Sofret Mariane",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always",
    "scheme": "Sofret Mariane",
    "backgroundColor": "#fbf5ea"
  },
  "android": {
    "backgroundColor": "#fbf5ea",
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#14241d",
      "showSpinner": false,
      "splashImmersive": true
    }
  }
}
